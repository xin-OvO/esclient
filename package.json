{
  "name": "esclient",
  "version": "0.1.0",
  "description": "一个类似 Navicat 的 Elasticsearch 中文桌面客户端",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "node scripts/run-tool.mjs tsc --noEmit && node scripts/run-tool.mjs electron-vite build",
    "build:main": "esbuild src/main/index.ts --bundle --platform=node --format=esm --external:electron --external:electron-store --external:@elastic/elasticsearch --outfile=out/main/index.js",
    "build:preload": "esbuild src/preload/index.ts --bundle --platform=node --format=esm --external:electron --outfile=out/preload/index.mjs",
    "build:renderer": "node scripts/build-renderer.mjs",
    "build:manual": "pnpm build",
    "pack:mac-local": "pnpm build && node scripts/package-mac-local.mjs",
    "dist": "pnpm build && node scripts/run-tool.mjs electron-builder",
    "preview": "electron-vite preview",
    "lint": "node scripts/run-tool.mjs tsc --noEmit"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.19.1",
    "@vitejs/plugin-react": "^5.1.1",
    "antd": "^6.0.0",
    "electron-store": "^11.0.2",
    "lucide-react": "^0.561.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/node": "^24.10.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "electron": "39.8.10",
    "electron-builder": "^26.15.3",
    "electron-vite": "^4.0.0",
    "esbuild": "0.25.12",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  },
  "build": {
    "appId": "com.wangxin.esclient",
    "productName": "ES 中文客户端",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "zip"
      ],
      "category": "Development",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
